<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<AnchorPane prefHeight="400.0" prefWidth="400.0" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.registrochamados.TelaCadastroController">
    <children>
        <VBox alignment="CENTER" layoutX="10.0" layoutY="10.0" prefHeight="380.0" prefWidth="380.0" spacing="15.0">
            <children>
                <Label text="Cadastro">
                    <font>
                        <Font name="System Bold" size="29.0" />
                    </font>
               <VBox.margin>
                  <Insets bottom="40.0" />
               </VBox.margin>
                </Label>
                <TextField fx:id="txtCadastrarNome" promptText="Nome" style="-fx-background-radius: 10;">
                    <font>
                        <Font size="14.0" />
                    </font>
                </TextField>
                <TextField fx:id="txtCadastrarUsuario" promptText="Usuario" style="-fx-background-radius: 10;">
                    <font>
                        <Font size="14.0" />
                    </font>
                </TextField>
                <TextField fx:id="txtCadastrarSenha" promptText="Senha" style="-fx-background-radius: 10;">
                    <font>
                        <Font size="14.0" />
                    </font>
                </TextField>
                <Button layoutX="200.0" layoutY="200.0" mnemonicParsing="false" onAction="#btnCadastrar" style="-fx-background-radius: 10; -fx-border-radius: 15;" text="Cadastrar">
                    <VBox.margin>
                        <Insets top="23.0" />
                    </VBox.margin>
                    <font>
                        <Font size="13.0" />
                    </font>
                </Button>
            </children>
        </VBox>
    </children>
</AnchorPane>
